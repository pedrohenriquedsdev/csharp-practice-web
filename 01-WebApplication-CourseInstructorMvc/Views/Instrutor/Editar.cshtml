@{
    Layout = "_Layout";
    ViewBag.Titulo = "Edição de Instrutor";
}

@model EditarInstrutorViewModel;

<form class="formulario" action="/Instrutor/Editar/@Model.Id" method="post">
    <div class="formulario-campo">
        <label>Nome</label>
        <br>
        <input type="text" name="Nome" value="@Model.Nome">
    </div>

    <div class="formulario-campo">
        <label>Email</label>
        <br>
        <input type="email" name="Email" value="@Model.Email">
    </div>

    <div class="formulario-campo">
        <label>Telefone</label>
        <br>
        <input type="text" name="Telefone" value="@Model.Telefone">
    </div>

    <div class="formulario-acoes">
        <a href="/Instrutor/Listar">Voltar</a>
        <button type="submit">Confirmar</button>
    </div>
</form>